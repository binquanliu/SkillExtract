  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 使用知识库进行技能提取\n",
    "\n",
    "现在我们已经有了知识库，可以用它来从文本中提取技能了。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 加载知识库\n",
    "# ============================================================================\n",
    "\n",
    "kb_path = output_pkl_path  # 使用刚才生成的知识库\n",
    "\n",
    "with open(kb_path, 'rb') as f:\n",
    "    onet_kb = pickle.load(f)\n",
    "\n",
    "print(f\"✓ 加载知识库: {len(onet_kb)} 个技能\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 定义查询方法\n",
    "# ============================================================================\n",
    "\n",
    "def query_method(query: str):\n",
    "    \"\"\"在知识库中查询技能\"\"\"\n",
    "    return onet_kb.get(query.lower(), [])\n",
    "\n",
    "print(\"✓ 查询方法已定义\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 配置：输入你要分析的文本\n",
    "# ============================================================================\n",
    "\n",
    "text_to_analyze = \"\"\"\n",
    "Senior Software Engineer with 8 years of experience.\n",
    "\n",
    "Core Competencies:\n",
    "- Strong judgment and decision making\n",
    "- Complex problem solving and critical thinking\n",
    "- Excellent coordination and communication skills\n",
    "- Proficient in Microsoft Excel and Microsoft Word\n",
    "- Experience with accounting software like QuickBooks\n",
    "- Financial operations and budget management\n",
    "\"\"\"\n",
    "\n",
    "print(\"待分析文本:\")\n",
    "print(text_to_analyze)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 构建提取 Pipeline\n",
    "# ============================================================================\n",
    "\n",
    "doc = Document()\n",
    "\n",
    "pipeline = Pipeline()\n",
    "\n",
    "# 1. 文本加载器\n",
    "pipeline.add_node(\n",
    "    StrTextLoader(text_to_analyze),\n",
    "    name='loader'\n",
    ")\n",
    "\n",
    "# 2. 滑动窗口匹配器\n",
    "pipeline.add_node(\n",
    "    SlidingWindowMatcher(\n",
    "        query_method,\n",
    "        max_window_size=5,  # 最大窗口大小（技能名称的最大词数）\n",
    "        pre_filter=lambda word: word.lower()  # 转小写进行匹配\n",
    "    ),\n",
    "    name='matcher'\n",
    ")\n",
    "\n",
    "# 3. 冲突解决器\n",
    "pipeline.add_node(\n",
    "    SpanProcessor(\n",
    "        dict_filters={\n",
    "            \"max_candidate\": lambda span: max(span.li_candidates, key=len)\n",
    "        }\n",
    "    ),\n",
    "    name='resolver'\n",
    ")\n",
    "\n",
    "print(\"✓ Pipeline 已构建\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 运行提取\n",
    "# ============================================================================\n",
    "\n",
    "pipeline.run(doc)\n",
    "\n",
    "print(\"✓ 提取完成！\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 显示结果\n",
    "# ============================================================================\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"提取的技能\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "extracted_skills = []\n",
    "\n",
    "for sentence_idx, sentence in enumerate(doc, start=1):\n",
    "    if not sentence.li_spans:\n",
    "        continue\n",
    "    \n",
    "    print(f\"\\n句子 {sentence_idx}: {str(sentence)}\")\n",
    "    print(\"-\" * 70)\n",
    "    \n",
    "    for span in sentence.li_spans:\n",
    "        candidate = span.metadata.get('max_candidate')\n",
    "        if candidate:\n",
    "            skill_text = ' '.join(sentence[candidate.window])\n",
    "            skill_info = candidate.metadata\n",
    "            \n",
    "            print(f\"  ✓ {skill_text}\")\n",
    "            print(f\"    类别: {skill_info['section']}\")\n",
    "            print(f\"    相关职业: {skill_info['occupation_title']}\")\n",
    "            \n",
    "            extracted_skills.append({\n",
    "                'skill': skill_text,\n",
    "                'section': skill_info['section'],\n",
    "                'occupation': skill_info['occupation_title']\n",
    "            })\n",
    "\n",
    "print(f\"\\n{'='*70}\")\n",
    "print(f\"总计找到 {len(extracted_skills)} 个技能\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
