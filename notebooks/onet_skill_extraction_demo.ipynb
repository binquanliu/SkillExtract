   "source": [
    "## 4. 实际应用示例\n",
    "\n",
    "### 示例 1: 分析多个候选人的简历"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 示例简历\n",
    "resumes = {\n",
    "    \"候选人A\": \"\"\"\n",
    "    Software Developer with expertise in critical thinking and complex problem solving.\n",
    "    Proficient in Microsoft Excel, Word, and PowerPoint.\n",
    "    \"\"\",\n",
    "    \n",
    "    \"候选人B\": \"\"\"\n",
    "    Chief Executive with strong judgment and decision making skills.\n",
    "    Experience in management of financial resources and coordination.\n",
    "    Familiar with accounting software including QuickBooks.\n",
    "    \"\"\",\n",
    "    \n",
    "    \"候选人C\": \"\"\"\n",
    "    Data Analyst skilled in spreadsheet software like Excel.\n",
    "    Strong analytical and critical thinking abilities.\n",
    "    \"\"\"\n",
    "}\n",
    "\n",
    "# 分析每个简历\n",
    "results = {}\n",
    "\n",
    "for name, resume in resumes.items():\n",
    "    doc = Document()\n",
    "    pipeline = Pipeline()\n",
    "    \n",
    "    pipeline.add_node(StrTextLoader(resume), name='loader')\n",
    "    pipeline.add_node(\n",
    "        SlidingWindowMatcher(query_method, max_window_size=5,\n",
    "                            pre_filter=lambda w: w.lower()),\n",
    "        name='matcher'\n",
    "    )\n",
    "    pipeline.add_node(\n",
    "        SpanProcessor(dict_filters={'max_candidate': lambda span: max(span.li_candidates, key=len)}),\n",
    "        name='resolver'\n",
    "    )\n",
    "    \n",
    "    pipeline.run(doc)\n",
    "    \n",
    "    # 收集技能\n",
    "    skills = []\n",
    "    for sentence in doc:\n",
    "        for span in sentence.li_spans:\n",
    "            candidate = span.metadata.get('max_candidate')\n",
    "            if candidate:\n",
    "                skill = ' '.join(sentence[candidate.window])\n",
    "                skills.append(skill)\n",
    "    \n",
    "    results[name] = skills\n",
    "\n",
    "# 显示结果\n",
    "print(\"=\" * 70)\n",
    "print(\"候选人技能对比\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "for name, skills in results.items():\n",
    "    print(f\"\\n{name}: {len(skills)} 个技能\")\n",
    "    for skill in skills:\n",
    "        print(f\"  ✓ {skill}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 示例 2: 技能频率分析"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from collections import Counter\n",
    "\n",
    "# 统计所有技能出现频率\n",
    "all_skills = []\n",
    "for skills in results.values():\n",
    "    all_skills.extend([s.lower() for s in skills])\n",
    "\n",
    "skill_counts = Counter(all_skills)\n",
    "\n",
    "print(\"技能频率统计:\")\n",
    "print(\"=\" * 70)\n",
    "for skill, count in skill_counts.most_common(10):\n",
    "    print(f\"{skill:40} : {count} 次\")"
   ]
