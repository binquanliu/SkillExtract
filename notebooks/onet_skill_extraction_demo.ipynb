   "source": [
    "import json\n",
    "import pickle\n",
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "# 添加项目根目录到路径\n",
    "project_root = Path.cwd().parent if 'notebooks' in str(Path.cwd()) else Path.cwd()\n",
    "sys.path.insert(0, str(project_root))\n",
    "\n",
    "# 导入 SkillNER\n",
    "from skillner.core import Pipeline, Document\n",
    "from skillner.text_loaders import StrTextLoader\n",
    "from skillner.matchers import SlidingWindowMatcher\n",
    "from skillner.conflict_resolvers import SpanProcessor\n",
    "\n",
    "print(\"✓ 导入成功！\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 从句子中提取技能关键词\n",
    "\n",
    "### 方法 1：使用函数直接调用（推荐）"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 技能提取函数（可以直接在 notebook 中使用）\n",
    "# ============================================================================\n",
    "\n",
    "import re\n",
    "from typing import List, Dict\n",
    "\n",
    "def extract_skill_name_before_dash(text: str) -> str:\n",
    "    \"\"\"从格式化文本中提取技能名称（"—" 之前的部分）\"\"\"\n",
    "    if '—' in text:\n",
    "        return text.split('—', 1)[0].strip()\n",
    "    elif '–' in text:\n",
    "        return text.split('–', 1)[0].strip()\n",
    "    return text.strip()\n",
    "\n",
    "def extract_technology_skills(text: str) -> List[str]:\n",
    "    \"\"\"提取技术技能列表\"\"\"\n",
    "    skills = []\n",
    "    if '—' in text:\n",
    "        parts = text.split('—', 1)\n",
    "        if len(parts) > 1:\n",
    "            items = parts[1].split(';')\n",
    "            for item in items:\n",
    "                item = re.sub(r'\\d+\\s*more\\s*$', '', item)\n",
    "                item = item.strip()\n",
    "                if item:\n",
    "                    skills.append(item)\n",
    "    return skills\n",
    "\n",
    "def extract_skills_from_onet_data(\n",
    "    onet_data: dict,\n",
    "    method: str = 'auto',\n",
    "    sections: List[str] = None\n",
    ") -> Dict[str, List[Dict]]:\n",
    "    \"\"\"\n",
    "    从 ONET 数据中提取技能\n",
    "    \n",
    "    参数:\n",
    "        onet_data: ONET 数据（字典格式）\n",
    "        method: 提取方法 ('auto', 'pattern')\n",
    "        sections: 要处理的 sections 列表\n",
    "    \n",
    "    返回:\n",
    "        SkillNER 格式的知识库字典\n",
    "    \"\"\"\n",
    "    if sections is None:\n",
    "        sections = ['Skills', 'Technology Skills', 'Work Activities', \n",
    "                   'Detailed Work Activities']\n",
    "    \n",
    "    knowledge_base = {}\n",
    "    occupation_code = onet_data.get('code', 'unknown')\n",
    "    occupation_title = onet_data.get('title', 'unknown')\n",
    "    \n",
    "    for section_name in sections:\n",
    "        section_data = onet_data.get('sections', {}).get(section_name)\n",
    "        if not section_data or section_data.get('type') != 'list':\n",
    "            continue\n",
    "        \n",
    "        items = section_data.get('items', [])\n",
    "        \n",
    "        for idx, item in enumerate(items):\n",
    "            extracted_skills = []\n",
    "            \n",
    "            # 自动模式：根据 section 类型选择方法\n",
    "            if section_name == 'Technology Skills':\n",
    "                # 提取类别名\n",
    "                skill_name = extract_skill_name_before_dash(item)\n",
    "                extracted_skills.append(skill_name)\n",
    "                # 提取具体工具\n",
    "                tech_items = extract_technology_skills(item)\n",
    "                extracted_skills.extend(tech_items)\n",
    "            else:\n",
    "                # 提取 "—" 之前的技能名\n",
    "                skill_name = extract_skill_name_before_dash(item)\n",
    "                extracted_skills.append(skill_name)\n",
    "            \n",
    "            # 添加到知识库\n",
    "            for skill_name in extracted_skills:\n",
    "                if not skill_name or len(skill_name) < 2:\n",
    "                    continue\n",
    "                \n",
    "                skill_key = skill_name.lower()\n",
    "                skill_entry = {\n",
    "                    'concept_id': f'onet:{occupation_code}:{section_name}:{idx}:{skill_name}',\n",
    "                    'pref_label': skill_name,\n",
    "                    'occupation_code': occupation_code,\n",
    "                    'occupation_title': occupation_title,\n",
    "                    'section': section_name,\n",
    "                    'original_text': item\n",
    "                }\n",
    "                \n",
    "                if skill_key in knowledge_base:\n",
    "                    knowledge_base[skill_key].append(skill_entry)\n",
    "                else:\n",
    "                    knowledge_base[skill_key] = [skill_entry]\n",
    "    \n",
    "    return knowledge_base\n",
    "\n",
    "print(\"✓ 提取函数定义完成！\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 示例：从 ONET JSON 提取技能"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 配置：设置你的输入输出路径\n",
    "# ============================================================================\n",
    "\n",
    "# 输入：你的 ONET JSON 文件路径\n",
    "input_json_path = '../tests/test_onet_sample.json'  # 修改为你的文件路径\n",
    "\n",
    "# 输出：生成的知识库保存路径\n",
    "output_pkl_path = '../.skillner-kb/ONET_EN.pkl'  # 修改为你想要的路径\n",
    "\n",
    "# 可选：选择要处理的 sections\n",
    "sections_to_process = ['Skills', 'Technology Skills', 'Work Activities', 'Detailed Work Activities']\n",
    "\n",
    "print(f\"输入文件: {input_json_path}\")\n",
    "print(f\"输出文件: {output_pkl_path}\")\n",
    "print(f\"处理的 sections: {', '.join(sections_to_process)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 执行：加载 JSON 并提取技能\n",
    "# ============================================================================\n",
    "\n",
    "# 读取 ONET JSON\n",
    "with open(input_json_path, 'r', encoding='utf-8') as f:\n",
    "    onet_data = json.load(f)\n",
    "\n",
    "# 如果是数组，处理每个职业\n",
    "if isinstance(onet_data, list):\n",
    "    print(f\"发现 {len(onet_data)} 个职业\\n\")\n",
    "    \n",
    "    all_kbs = []\n",
    "    for occupation in onet_data:\n",
    "        kb = extract_skills_from_onet_data(occupation, sections=sections_to_process)\n",
    "        all_kbs.append(kb)\n",
    "        print(f\"✓ {occupation.get('title', 'Unknown')}: {len(kb)} 个技能\")\n",
    "    \n",
    "    # 合并所有知识库\n",
    "    final_kb = {}\n",
    "    for kb in all_kbs:\n",
    "        for skill_name, entries in kb.items():\n",
    "            if skill_name in final_kb:\n",
    "                final_kb[skill_name].extend(entries)\n",
    "            else:\n",
    "                final_kb[skill_name] = entries\n",
    "else:\n",
    "    # 单个职业\n",
    "    print(f\"处理职业: {onet_data.get('title', 'Unknown')}\\n\")\n",
    "    final_kb = extract_skills_from_onet_data(onet_data, sections=sections_to_process)\n",
    "\n",
    "print(f\"\\n总计: {len(final_kb)} 个独特技能\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# 保存知识库\n",
    "# ============================================================================\n",
    "\n",
    "# 确保输出目录存在\n",
    "Path(output_pkl_path).parent.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# 保存为 pickle\n",
    "with open(output_pkl_path, 'wb') as f:\n",
    "    pickle.dump(final_kb, f)\n",
    "\n",
    "print(f\"✓ 知识库已保存到: {output_pkl_path}\")\n",
    "print(f\"  文件大小: {Path(output_pkl_path).stat().st_size / 1024:.1f} KB\")"
   ]
  },
  {
   "cell_type": "markdown",
